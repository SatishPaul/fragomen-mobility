# Copy to .env.local (local) or set in the Vercel dashboard (production).

# Required for multi-user authentication, database records, and private videos.
# Create a Supabase project, then copy these values from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical HTTPS origin used in invitation and recovery links.
# Production example: https://fragomen-mobility.vercel.app
NEXT_PUBLIC_APP_URL=

# Server-side only. Never expose this key with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Email address promoted to admin by the initial database bootstrap.
INITIAL_ADMIN_EMAIL=

# Server-side only. Used to verify Outstand webhook signatures.
OUTSTAND_WEBHOOK_SECRET=

# Required — your own OpenRouter key (https://openrouter.ai/keys).
# Server-side only; never shipped to the browser.
OPENROUTER_API_KEY=

# Legacy fallback only. Remove after Supabase Auth is configured.
# APP_PASSWORD=

# Optional — override the default free-tier model IDs (see config/models.ts).
# OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_SCRIPT_MODEL=openai/gpt-oss-20b:free

# Optional — higher-quality voiceover via a server TTS provider.
# OpenRouter has NO free TTS models, so the free path is a Groq key
# (free at https://console.groq.com). With GROQ_API_KEY set, Groq voices are
# used automatically; without it the app uses the in-browser voice at $0.
# GROQ_API_KEY=
# TTS_PROVIDER=auto        # auto | groq | openrouter | off
# Set TTS_PROVIDER=openrouter ONLY if your OpenRouter account has purchased
# credits (uses openai/gpt-audio-mini, a paid model).

# Optional — enable authenticated social publishing through Outstand.
# OUTSTAND_API_KEY=
# SOCIAL_VIDEO_MAX_BYTES=524288000
